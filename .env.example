# TerraMind environment template
# Copy this file to .env and fill in local values. Never commit .env.

# Real RAG mode
USE_MOCK=false
OPENAI_API_KEY=sk-your-key-here

# Local gateway defaults. Docker compose overrides RAG_SERVICE_URL inside containers.
RAG_SERVICE_URL=http://localhost:8001/query
REQUEST_TIMEOUT=90

# Optional local/provider overrides
# VISION_PROVIDER=openai
# VISION_API_KEY=
# VISION_MODEL=gpt-4o-mini
# LLM_PROVIDER=
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=
