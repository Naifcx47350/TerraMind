# TEMPLATE ONLY — committed to git. Copy to repo root as .env (never commit .env).
#
#   Windows:  copy docker\env.example .env
#   macOS/Linux:  cp docker/env.example .env
#
# Real file location (Docker reads THIS path only):
#   <repo-root>/.env     e.g.  c:\workspace_47\TerraMind\.env
#
# NOT docker/.env — Compose does not use that folder for secrets.

# --- Real RAG (recommended for Docker) ---
USE_MOCK=false
OPENAI_API_KEY=sk-your-key-here

# --- Demo mode (no key, canned answers — skip init-indexes) ---
# USE_MOCK=true

# RAG_SERVICE_URL is set automatically in docker-compose.yml for containers.
# REQUEST_TIMEOUT=90 is optional (local FrontPage dev only).
