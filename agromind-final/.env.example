USE_MOCK=true

# ── LLM Provider (pick one) ──────────────────────
# Options: openai, groq, anthropic, together, openrouter, local
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ── Vision Provider (for image analysis) ─────────
# Options: openai, anthropic (must support vision)
VISION_PROVIDER=
VISION_API_KEY=
VISION_MODEL=
VISION_BASE_URL=

# ── RAG Service (when team is ready) ─────────────
# Point to your team's RAG endpoint (full URL)
# Example: RAG_SERVICE_URL=http://localhost:8001/query
RAG_SERVICE_URL=

REQUEST_TIMEOUT=30

# ── Examples ─────────────────────────────────────
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-xxxx
#   LLM_MODEL=gpt-4o
#
# Groq:
#   LLM_PROVIDER=groq
#   LLM_API_KEY=gsk_xxxx
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Anthropic:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-xxxx
#   LLM_MODEL=claude-sonnet-4-20250514
#
# Together AI:
#   LLM_PROVIDER=together
#   LLM_API_KEY=xxxx
#   LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# OpenRouter:
#   LLM_PROVIDER=openrouter
#   LLM_API_KEY=sk-or-xxxx
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#
# Local (Ollama):
#   LLM_PROVIDER=local
#   LLM_MODEL=llama3
#   LLM_BASE_URL=http://localhost:11434/api/chat
#
# Vision (OpenAI):
#   VISION_PROVIDER=openai
#   VISION_API_KEY=sk-xxxx
#   VISION_MODEL=gpt-4o
#
# Vision (Anthropic):
#   VISION_PROVIDER=anthropic
#   VISION_API_KEY=sk-ant-xxxx
#   VISION_MODEL=claude-sonnet-4-20250514
