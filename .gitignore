# TerraMind — local/generated paths (see data/README.md for corpus layout)

# === Vector indexes (rebuild with Rag_Pc / terramind.rag.general.cli) ===
vectorstore/

# === Generated outputs ===
data/eval/runs/
data/processed/

# === Large / non-RAG datasets (not used by web MVP indexes) ===
data/raw/PlantVillage/
data/raw/Fine tuning data/

# === Eval fixtures & sample text (tracked in git) ===
# Negations apply only if a parent rule ignores `data/`; corpus PDFs live under
# `data/raw/documents/` and are tracked normally.
!data/eval/
!data/eval/**
!data/sample/
!data/sample/**

